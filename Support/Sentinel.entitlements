<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime gates camera access on this entitlement, in addition to
	     the NSCameraUsageDescription prompt string in Info.plist. -->
	<key>com.apple.security.device.camera</key>
	<true/>
</dict>
</plist>
